#!/bin/bash

RED="\033[38;5;160m"
YELLOW="\033[38;5;220m"
GREEN="\033[38;5;40m"
NC='\033[0m'


format_percent() {
    local value=$1
    local rounded=$(echo "$1" | awk '{printf "%.0f", $1}')
    local color=$NC

    if [ "$2" = "true" ]; then
        if [ "$rounded" -lt 30 ]; then
            color=$GREEN
        elif [ "$rounded" -lt 70 ]; then
            color=$YELLOW
        else
            color=$RED
        fi
    else
        if [ "$rounded" -lt 30 ]; then
            color=$RED
        elif [ "$rounded" -lt 70 ]; then
            color=$YELLOW
        else
            color=$GREEN
        fi
    fi

    echo -e "${color}${value}%${NC}"
}

print_info() {
    local label="$1"
    local value="$2"
    printf "%-20s: %s\n" "$label" "$value"
}

get_main_disk() {
    local root_dev=$(df / | awk 'NR==2 {print $1}' | sed 's/[0-9]*$//' | sed 's/p$//')
    root_dev=$(basename "$root_dev")
    echo "$root_dev"
}
main_disk=$(get_main_disk)

print_cpu() {
    echo -e "\t=== CPU ===\n"

    # -- Model --
    model=$(awk -F': ' '/model name/ {print $2; exit}' /proc/cpuinfo)

    if [ -n "$model" ]; then
        print_info "Model name" "$model"
    else
        echo "\tModel name: N/A" >&2
    fi

    # -- Cores number --
    cores=$(awk -F': ' '/^cpu cores/ {print $2; exit}' /proc/cpuinfo)
    if [ -n "$cores" ]; then
        print_info "Cores number" "$cores"
    else
        cores=$(grep -c "^processor" /proc/cpuinfo)
        print_info "Cores number (logical)" "$cores"
    fi

    # -- Current frequency --
    freq=$(awk -F': ' '/^cpu MHz/ {print $2; exit}' /proc/cpuinfo)
    if [ -n "$freq" ]; then
        print_info "Frequency" "$freq MHz"
    else
        freq_alt=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_cur_freq 2>/dev/null)
        if [ -n "$freq_alt" ]; then
            print_info "Frequency" "$freq_alt kHz"
        else
            echo "\tFrequency: N/A" >&2
        fi
    fi

    # -- Min/Max frequency --
    if [ -f /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq ]; then
        min_freq=$(($(cat /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_min_freq) / 1000))
        max_freq=$(($(cat /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq) / 1000))
        print_info "Min/Max frequency" "${min_freq} / ${max_freq} MHz"
    fi

    # -- Current governor --

    if [ -f /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor ]; then
        gov=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor)
        print_info "Governor" "$gov"
    fi

    # -- CPU0 temp Celsuis

    if [ -f /sys/class/thermal/thermal_zone0/temp ]; then
        temp=$(($(cat /sys/class/thermal/thermal_zone0/temp) / 1000))
        print_info "Temperature" "${temp}°C"
    fi
}

print_gpu() {
    printf "\t=== GPU ===\n"

    if ! command -v lspci >/dev/null 2>&1; then
        echo -e "\tGPU: N/A (lspci not found)" >&2
        return 1
    fi

    local gpus=$(lspci -mm 2>/dev/null | grep -E "VGA|3D|Display")

    if [ -z "$gpus" ]; then
        echo -e "\tGPU: Not detected" >&2
        return 1
    fi

    local count=$(echo "$gpus" | wc -l)
    local num=0

    while IFS= read -r line; do
        num=$((num + 1))

        if [ "$count" -gt 1 ]; then
            printf "\t--- GPU %d ---\n" "$num"
        fi

        local bus=$(echo "$line" | awk '{print $1}')
        local vendor=$(echo "$line" | awk -F'"' '{print $4}' | xargs)
        local raw_model=$(echo "$line" | awk -F'"' '{print $6}' | xargs)

        # -- pretty gpu name --
        local pretty_model=$(get_pretty_gpu_name "$raw_model" "$vendor")

        print_info "Model" "$pretty_model"
        print_info "Vendor" "$vendor"
        print_info "Bus" "$bus"

        # -- Subsystem --
        local quote_count=$(echo "$line" | grep -o '"' | wc -l)
        if [ "$quote_count" -ge 8 ]; then
            local subsys_vendor=$(echo "$line" | awk -F'"' '{print $8}' | xargs)
            [ -n "$subsys_vendor" ] && [ "$subsys_vendor" != "$vendor" ] && \
                print_info "Subsystem" "$subsys_vendor"
        fi

        # -- Driver --
        local driver=$(lspci -k -s "$bus" 2>/dev/null | grep -E "kernel driver|Kernel driver" | awk -F': ' '{print $2}' | head -1)
        [ -n "$driver" ] && print_info "Driver" "$driver"

        # -- Revision --
        if [[ "$line" =~ -r([0-9a-fA-F]+) ]]; then
            print_info "Revision" "${BASH_REMATCH[1]}"
        fi

        echo ""
    done <<< "$gpus"
}

get_pretty_gpu_name() {
    local raw="$1"
    local vendor="$2"
    local pretty=""

    if [[ "$raw" =~ \[([^]]+)\] ]]; then
        pretty="${BASH_REMATCH[1]}"
    else
        pretty="$raw"
    fi

    pretty=$(echo "$pretty" | sed -E 's/^[A-Za-z0-9]+ [0-9]+ \[//' | sed 's/\]$//')

    if [ -z "$pretty" ] || [ "$pretty" = "$raw" ]; then
        pretty=$(echo "$raw" | sed "s/^$vendor //" | sed 's/^.*\[//' | sed 's/\]$//')
    fi

    if echo "$vendor" | grep -qi "amd"; then
        if [[ ! "$pretty" =~ Radeon ]]; then
            pretty="Radeon $pretty"
        fi
        pretty=$(echo "$pretty" | sed 's/\[[^]]*\]//g')
    fi

    if echo "$vendor" | grep -qi "nvidia"; then
        if [[ ! "$pretty" =~ GeForce ]] && [[ ! "$pretty" =~ Quadro ]]; then
            pretty="GeForce $pretty"
        fi
    fi

    pretty=$(echo "$pretty" | xargs | sed 's/  */ /g')

    if [ -z "$pretty" ]; then
        pretty="$raw"
    fi

    echo "$pretty"
}

print_vulkan() {
    if command -v vulkaninfo >/dev/null 2>&1; then
        local vulkan_output=$(vulkaninfo --summary 2>/dev/null)

        if [ -n "$vulkan_output" ]; then
            echo -e "\t--- Vulkan ---"

            local api_version=$(echo "$vulkan_output" | awk -F'=' '/apiVersion/ {print $2; exit}' | xargs)
            local driver_info=$(echo "$vulkan_output" | awk -F'=' '/driverInfo/ {print $2; exit}' | xargs)
            local device_name=$(echo "$vulkan_output" | awk -F'=' '/deviceName/ {print $2; exit}' | xargs)

            [ -n "$api_version" ] && print_info "API version" "$api_version"
            [ -n "$driver_info" ] && print_info "Driver" "$driver_info"
            [ -n "$device_name" ] && print_info "Device" "$device_name"
        fi
    fi
}

print_opengl() {
    echo -e "\t--- OpenGL ---"

    if ! command -v glxinfo >/dev/null 2>&1; then
        echo -e "\tOpenGL: N/A (glxinfo not found)" >&2
        return 1
    fi

    local gl_full=$(glxinfo 2>/dev/null)
    local gl_basic=$(glxinfo -B 2>/dev/null)

    if [ -n "$gl_basic" ]; then
        local gl_version=$(echo "$gl_basic" | grep -m1 "OpenGL version" | cut -d':' -f2 | xargs)
        local gl_renderer=$(echo "$gl_basic" | grep -m1 "OpenGL renderer" | cut -d':' -f2 | xargs)
        local gl_vendor=$(echo "$gl_basic" | grep -m1 "OpenGL vendor" | cut -d':' -f2 | xargs)
        local glsl_version=$(echo "$gl_basic" | grep -m1 "OpenGL shading language version" | cut -d':' -f2 | xargs)

        [ -n "$gl_version" ] && print_info "Version" "$gl_version"
        [ -n "$gl_renderer" ] && print_info "Renderer" "$gl_renderer"
        [ -n "$gl_vendor" ] && print_info "Vendor" "$gl_vendor"
        [ -n "$glsl_version" ] && print_info "GLSL" "$glsl_version"


        local ext_count=$(echo "$gl_full" | grep -c "GL_*")
        if [ -n "$ext_count" ] && [ "$ext_count" -gt 0 ]; then
            print_info "Extensions count" "$ext_count"
        fi

        if echo "$gl_renderer" | grep -qi "software"; then
            print_info "Hardware accel" "No (software rendering)"
        else
            print_info "Hardware accel" "Yes"
        fi
    else
        echo -e "\tOpenGL: No information available" >&2
    fi
}

print_battery(){
    if [ ! -d /sys/class/power_supply/BAT0 ]; then
        return 1
    fi

    echo -e "\t=== BATTERY ===\n"


    # -- Capacity --
    if [ -f /sys/class/power_supply/BAT0/capacity ]; then
        capacity=$(format_percent "$(cat /sys/class/power_supply/BAT0/capacity)")
        print_info "Capacity" "${capacity}"
    fi

    # -- Battery status --
    if [ -f /sys/class/power_supply/BAT0/status ]; then
        bat_status=$(cat /sys/class/power_supply/BAT0/status)
        print_info "Status" "${bat_status}"
    fi

    # -- Charge threshold --
    if [ -f /sys/class/power_supply/BAT0/charge_control_end_threshold ] && \
       [ -f /sys/class/power_supply/BAT0/charge_control_start_threshold ]; then
        start_threshold=$(cat /sys/class/power_supply/BAT0/charge_control_start_threshold)
        end_threshold=$(cat /sys/class/power_supply/BAT0/charge_control_end_threshold)

        print_info "Threshold" "${start_threshold}% - ${end_threshold}%"
    fi

    # -- Cycles --
    if [ -f /sys/class/power_supply/BAT0/cycle_count ]; then
        cycles=$(cat /sys/class/power_supply/BAT0/cycle_count)
        print_info "Cycles count" "${cycles}"
    fi

    # -- Battery health
    if [ -f /sys/class/power_supply/BAT0/energy_full_design ] && \
       [ -f /sys/class/power_supply/BAT0/energy_full ]; then
        energy_full_design=$(cat /sys/class/power_supply/BAT0/energy_full_design)
        energy_full=$(cat /sys/class/power_supply/BAT0/energy_full)
        percentage=$(echo "scale=2; $energy_full * 100 / $energy_full_design" | bc)
        print_info "Battery health" "$(format_percent "${percentage}")"
    fi

    # -- Power --
    if [ -f /sys/class/power_supply/BAT0/power_now ]; then
        formatted_power=$(echo "scale=2; $(cat /sys/class/power_supply/BAT0/power_now) / 1000000" | bc)
        print_info "Power" "${formatted_power}W"
    fi

    # -- Time to empty/full --
    if command -v upower >/dev/null 2>&1; then
      battery_path=$(upower -e | grep -i bat | head -1)
      if [ "$bat_status" = "Discharging" ]; then
        time_str=$(upower -i "$battery_path" | grep "time to empty" | awk -F': ' '{gsub(/^[ \t]+/, "", $2); print $2}')
        if [ -n "$time_str" ] ; then
          print_info "Time to empty" "${time_str}"
        else
          print_info "Time to empty" "N/A"
        fi
      elif [ "$bat_status" = "Charging" ]; then
        time_str=$(upower -i "$battery_path" | grep "time to full" | awk -F': ' '{gsub(/^[ \t]+/, "", $2); print $2}')

        if [ -n "$time_str" ] ; then
          print_info "Time to full" "${time_str}"
        else
          print_info "Time to full" "N/A"
        fi
      fi
    fi

    # -- Battery technology --
    if [ -f /sys/class/power_supply/BAT0/technology ]; then
        technology=$(cat /sys/class/power_supply/BAT0/technology)
        print_info "Technology" "${technology}"
    fi
}

print_ram() {
    echo -e "\t=== RAM ===\n"

    local meminfo=$(cat /proc/meminfo)

    # -- Total memory --
    local total=$(echo "$meminfo" | awk '/^MemTotal:/ {print $2}')
    if [ -n "$total" ]; then
        total_gb=$(echo "scale=1; $total / 1024 / 1024" | bc)

        local available=$(echo "$meminfo" | awk '/^MemAvailable:/ {print $2}')
        available_gb=$(echo "scale=1; $available / 1024 / 1024" | bc)
        # -- Used memory --
        if [ -n "$total" ] && [ -n "$available" ]; then
            used=$((total - available))
            used_gb=$(echo "scale=1; $used / 1024 / 1024" | bc)
            ram_percent=$(echo "$used * 100 / $total" | bc)
            print_info "RAM" "${used_gb} GB / $total_gb GB ($(format_percent $ram_percent "true"))"

        fi
    else
        echo "\tRAM: N/A" >&2
    fi



    # -- Swap total --
    local swap_total=$(echo "$meminfo" | awk '/^SwapTotal:/ {print $2}')
    if [ -n "$swap_total" ] && [ "$swap_total" -gt 0 ]; then
        swap_total_gb=$(echo "scale=1; $swap_total / 1024 / 1024" | bc)

        # -- Swap free --
        local swap_free=$(echo "$meminfo" | awk '/^SwapFree:/ {print $2}')
        if [ -n "$swap_free" ]; then
            swap_used=$((swap_total - swap_free))
            swap_free_gb=$(echo "scale=1; $swap_free / 1024 / 1024" | bc)
            swap_used_gb=$(echo "scale=1; $swap_used / 1024 / 1024" | bc)
            swap_percent=$(echo "$swap_used * 100 / $swap_total" | bc)
            print_info "Swap used" "${swap_used_gb} GB / ${swap_total_gb} GB ($(format_percent $swap_percent "true"))"
        fi
    fi

    if [ -n $available_gb ] && \
       [ -n $swap_free ]; then
        print_info "RAM free" "$available_gb GB"
        print_info "Swap free" "$swap_free_gb GB"
    fi

    # -- Cached memory --
    local cached=$(echo "$meminfo" | awk '/^Cached:/ {print $2}')
    if [ -n "$cached" ]; then
        cached_gb=$(echo "scale=1; $cached / 1024 / 1024" | bc)
        print_info "Cached memory" "${cached_gb} GB"
    fi
}

print_disk() {
    echo -e "\t=== DISK ===\n"

    if [ ! -d "/sys/block/$main_disk" ]; then
        echo -e "\tDisk: N/A" >&2
        return 1
    fi

    # -- Model --
    local model=""
    if [ -f "/sys/block/$main_disk/device/model" ]; then
        model=$(cat "/sys/block/$main_disk/device/model"  2>/dev/null | xargs)
    fi

    if [ -n "$model" ]; then
        print_info "Model" "$model"
    else
        print_info "Model" "Unknown"
    fi

    # -- Size --
    local size=$(cat "/sys/block/$main_disk/size" 2>/dev/null)
    if [ -n "$size" ] && [ "$size" -gt 0 ]; then
        local size_bytes=$((size * 512))
        local size_gb=$((size_bytes / 1024 / 1024 / 1024))
        local size_tb=$(echo "scale=1; $size_bytes / 1024 / 1024 / 1024 / 1024" | bc)

        if [ "$size_gb" -gt 1024 ]; then
            print_info "Size" "${size_tb} TB"
        else
            print_info "Size" "${size_gb} GB"
        fi
    else
        print_info "Size" "Unknown"
    fi

    # -- Type (SSD/HDD/NVMe) --
    local disk_type="Unknown"
    if [[ "$main_disk" =~ ^nvme ]]; then
        disk_type="NVMe"
    else
        local rotational=$(cat "/sys/block/$main_disk/queue/rotational" 2>/dev/null)
        if [ "$rotational" = "0" ]; then
            disk_type="SSD"
        elif [ "$rotational" = "1" ]; then
            disk_type="HDD"
        fi
    fi
    print_info "Type" "$disk_type"

    # -- Partitions --
    local partitions=$(ls -d "/sys/block/$main_disk/"*[0-9] 2>/dev/null | wc -l)
    if [ "$partitions" -gt 0 ]; then
        print_info "Partitions" "$partitions"
    fi

    # -- Root --
    local root_usage=$(df -h / | awk 'NR==2')
    if [ -n "$root_usage" ]; then
        local root_size=$(echo "$root_usage" | awk '{print $2}')
        local root_used=$(echo "$root_usage" | awk '{print $3}')
        local root_avail=$(echo "$root_usage" | awk '{print $4}')
        local root_percent=$(echo "$root_usage" | awk '{print $5}' | sed 's/%//')

        print_info "Root used / size" "$root_used / $root_size ($(format_percent "$root_percent" "true"))"
        print_info "Root available" "$root_avail"

    fi

}


print_mounts() {
    echo -e "\t=== MOUNTS ===\n"
    df -h | grep -E "^/dev/" | awk '!seen[$1]++'| while read line; do
        mount=$(echo "$line" | awk '{print $6}')
        size=$(echo "$line" | awk '{print $2}')
        used=$(echo "$line" | awk '{print $3}')
        percent=$(echo "$line" | awk '{print $5}' | sed 's/%//')

        colored_percent=$(format_percent "$percent" "true")
        print_info "$mount" "($used / $size) $colored_percent"
    done
}

print_net() {
    echo -e "\t=== NETWORK ===\n"

    for iface in /sys/class/net/*; do
        local iface_name=$(basename "$iface")
        [ "$iface_name" = "lo" ] && continue

        local operstate=$(cat "$iface/operstate" 2>/dev/null)

        printf "\t--- %s (%s) ---\n" "$iface_name" "$operstate"

        # -- MAC address --
        local mac=$(cat "$iface/address" 2>/dev/null)
        [ -n "$mac" ] && [ "$mac" != "00:00:00:00:00:00" ] && print_info "MAC" "$mac"

        # specific WiFi
        if [[ "$iface_name" =~ ^(wlan|wlp|wlx) ]] && [ "$operstate" = "up" ]; then
            local wifi_data=$(iw dev "$iface_name" link 2>/dev/null)

            if [ -n "$wifi_data" ]; then
                # -- SSID --
                local ssid=$(echo "$wifi_data" | grep "SSID:" | awk '{print $2}')
                [ -n "$ssid" ] && print_info "SSID" "$ssid"

                # -- Signal strength --
                local signal=$(echo "$wifi_data" | grep "signal:" | awk '{print $2}')
                if [ -n "$signal" ]; then
                    signal_percent=$(( 100 * ($signal + 90) / (60) ))
                    print_info "Signal" "${signal} dBm ($(format_percent "$signal_percent"))"
                fi

                # -- Bitrate --
                local bitrate=$(echo "$wifi_data" | grep "tx bitrate:" | awk -F': ' '{print $2}' | awk '{print $1}')
                [ -n "$bitrate" ] && print_info "Bitrate" "${bitrate} Mbps"

                # -- Frequency band --
                local freq=$(echo "$wifi_data" | grep "freq:" | awk '{print $2}')
                if [ -n "$freq" ]; then
                    local band="2.4 GHz"
                    [ "$(echo "$freq > 5000" | bc)" -eq 1 ] && band="5 GHz"
                    print_info "Band" "$band"
                fi
            else
                print_info "Status" "Not connected"
            fi
        fi

        # Ethernet
        if [ -f "$iface/speed" ] && [ "$operstate" = "up" ]; then
            local speed=$(cat "$iface/speed" 2>/dev/null)
            if [ -n "$speed" ] && [ "$speed" -ne 65535 ] && [ "$speed" -ne 0 ]; then
                print_info "Speed" "${speed} Mbps"
            fi
        fi

        # -- IP-address --
        if [ "$operstate" = "up" ]; then
            local ipv4=$(ip -4 addr show "$iface_name" 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}' | head -1)
            [ -n "$ipv4" ] && print_info "IPv4" "$ipv4"
        fi

        echo ""
    done
}


print_bluetooth() {
    echo -e "\t=== BLUETOOTH ===\n"

    if [ ! -d /sys/class/bluetooth/hci0 ]; then
        echo -e "\tNo Bluetooth adapter found" >&2
        return 1
    fi

    # -- Adapter name (via rfkill) --
    local name=""
    if [ -f /sys/class/bluetooth/hci0/rfkill0/name ]; then
        name=$(cat /sys/class/bluetooth/hci0/rfkill0/name 2>/dev/null)
    fi
    [ -n "$name" ] && print_info "Adapter" "$name"

    # -- MAC address --
    local mac=""
    if command -v bluetoothctl >/dev/null 2>&1; then
        mac=$(bluetoothctl show 2>/dev/null | grep "Controller" | awk '{print $2}')
    elif command -v hciconfig >/dev/null 2>&1; then
        mac=$(hciconfig -a 2>/dev/null | grep "BD Address" | awk '{print $3}')
    fi
    [ -n "$mac" ] && print_info "MAC" "$mac"

    # -- Blocked status (rfkill) --
    if [ -f /sys/class/bluetooth/hci0/rfkill0/soft ]; then
        local soft_blocked=$(cat /sys/class/bluetooth/hci0/rfkill0/soft 2>/dev/null)
        local hard_blocked=$(cat /sys/class/bluetooth/hci0/rfkill0/hard 2>/dev/null)

        if [ "$hard_blocked" = "1" ]; then
            print_info "Status" "Hardware blocked (switch off)"
        elif [ "$soft_blocked" = "1" ]; then
            print_info "Status" "Software blocked"
        else
            print_info "Status" "Active"
        fi
    fi

    # -- Power state (via bluetoothctl) --
    if command -v bluetoothctl >/dev/null 2>&1; then
        local powered=$(bluetoothctl show 2>/dev/null | grep "Powered:" | awk '{print $2}')
        if [ -n "$powered" ]; then
            [ "$powered" = "yes" ] && print_info "Powered" "Yes" || print_info "Powered" "No"
        fi
    fi

    # -- Paired/Connected devices --
    if command -v bluetoothctl >/dev/null 2>&1; then
        local devices_count=$(bluetoothctl devices 2>/dev/null | grep -c "Device")
        if [ "$devices_count" -gt 0 ]; then
            echo -e "\n\t--- Paired devices ($devices_count) ---"
            bluetoothctl devices 2>/dev/null | head -5 | while read -r line; do
                local dev_mac=$(echo "$line" | awk '{print $2}')
                local dev_name=$(echo "$line" | cut -d' ' -f3-)

                local connected=""
                if bluetoothctl info "$dev_mac" 2>/dev/null | grep -q "Connected: yes"; then
                    connected=" [connected]"
                fi
                printf " • %s%s\n" "$dev_name" "$connected"
            done
            [ "$devices_count" -gt 5 ] && echo "\t  ... and $((devices_count - 5)) more"
        else
            echo -e "\n\t--- No paired devices ---"
        fi
    fi
}

print_system() {
    echo -e "\t=== SYSTEM ===\n"

    # -- Hostname --
    local hostname=$(hostname 2>/dev/null)
    [ -n "$hostname" ] && print_info "Hostname" "$hostname"

    # -- Kernel --
    local kernel=$(uname -r 2>/dev/null)
    [ -n "$kernel" ] && print_info "Kernel" "$kernel"

    # -- Kernel version --
    local kernel_version=$(uname -v 2>/dev/null | cut -d' ' -f1-3)
    [ -n "$kernel_version" ] && print_info "Kernel version" "$kernel_version"

    # -- Architecture --
    local arch=$(uname -m 2>/dev/null)
    case "$arch" in
        x86_64)  arch="x86_64 (64-bit)" ;;
        i386|i486|i586|i686) arch="x86 (32-bit)" ;;
        aarch64) arch="ARM64 (64-bit)" ;;
        armv7l)  arch="ARMv7 (32-bit)" ;;
        *)       arch="$arch" ;;
    esac
    print_info "Architecture" "$arch"

    # -- OS / Distro --
    local os_name=""
    local os_version=""
    local os_id_like=""

    if [ -f /etc/os-release ]; then
        os_name=$(grep -E '^PRETTY_NAME=' /etc/os-release 2>/dev/null | cut -d'"' -f2)
        os_id_like=$(grep -E '^ID_LIKE=' /etc/os-release 2>/dev/null | cut -d'=' -f2 | tr -d '"')
        os_version=$(grep -E '^VERSION_ID=' /etc/os-release 2>/dev/null | cut -d'"' -f2)
    fi

    print_info "OS" "$os_name"

    # -- OS Version (если отдельно) --
    if [ -n "$os_version" ] && [[ ! "$os_name" =~ "$os_version" ]]; then
        print_info "OS Version" "$os_version"
    fi

    # -- OS ID LIKE --
    [ -n "$os_id_like" ] && print_info "OS ID like" "$os_id_like"

    # -- Uptime --
    local uptime_seconds=$(awk '{print int($1)}' /proc/uptime 2>/dev/null)
    if [ -n "$uptime_seconds" ]; then
        local days=$((uptime_seconds / 86400))
        local hours=$(((uptime_seconds % 86400) / 3600))
        local minutes=$(((uptime_seconds % 3600) / 60))

        local uptime_str=""
        [ "$days" -gt 0 ] && uptime_str="${days}d "
        [ "$hours" -gt 0 ] && uptime_str="${uptime_str}${hours}h "
        uptime_str="${uptime_str}${minutes}m"

        print_info "Uptime" "$uptime_str"
    fi

    # -- Load average --
    if [ -f /proc/loadavg ]; then
        local load=$(cat /proc/loadavg | awk '{print $1", "$2", "$3}')
        print_info "Load average" "$load"
    fi

    # -- Users logged in --
    local users=$(who 2>/dev/null | awk '{print $1}' | sort -u | wc -l)
    [ "$users" -gt 0 ] && print_info "Users logged" "$users"

    # -- Last boot --
    if command -v who >/dev/null 2>&1; then
        local last_boot=$(who -b 2>/dev/null | awk '{print $3, $4}')
        [ -n "$last_boot" ] && print_info "Last boot" "$last_boot"
    fi

    # -- Default shell --
    local shell=$(basename "$SHELL" 2>/dev/null)
    [ -n "$shell" ] && print_info "Default shell" "$shell"

    # -- Terminal --
    local term="$TERM"
    [ -n "$term" ] && print_info "Terminal" "$term"

    # -- Desktop environment (если есть) --
    if [ -n "$XDG_CURRENT_DESKTOP" ]; then
        print_info "Desktop" "$XDG_CURRENT_DESKTOP"
    elif [ -n "$DESKTOP_SESSION" ]; then
        print_info "Desktop" "$DESKTOP_SESSION"
    fi

    # -- Session type (X11/Wayland) --
    if [ -n "$XDG_SESSION_TYPE" ]; then
        print_info "Session" "$XDG_SESSION_TYPE"
    fi
}


# -- attribute parse --
case $1 in
    all|every)
        print_system
        print_cpu
        print_gpu
        print_vulkan
        print_opengl
        print_battery
        print_ram
        print_disk
        print_mounts
        print_net
        print_bluetooth
        ;;
    system|os)
        print_system
        ;;
    cpu|proc|precessor)
        print_cpu
        ;;
    gpu|graph)
        print_gpu
        print_vulkan
        print_opengl
        ;;
    battery|bat|baterry)
        print_battery
        ;;
    ram|memory|mem)
        print_ram
        ;;
    disk|dsk)
        print_disk
        ;;
    mount|mounts|mnt)
        print_mounts
        ;;
    net)
        print_net
        ;;
    bluetooth|blue)
        print_bluetooth
        ;;
    *|help|--help|-h)
        echo "Usage: system-info [OPTION]"
        echo ""
        print_info "all/every" "Full system info"
        print_info "system/os" "OS info"
        print_info "cpu/proc/processor" "CPU info"
        print_info "gpu/graph" "GPU + Vulkan + OpenGL"
        print_info "battery/bat" "Battery info"
        print_info "ram/memory/mem" "RAM info"
        print_info "disk/dsk" "Disk info"
        print_info "mount/mounts/mnt" "Mounts info"
        print_info "net" "Network info"
        print_info "bluetooth/blue" "Bluetooth info"
        print_info "help/--help/-h" "This help"
        ;;
esac
